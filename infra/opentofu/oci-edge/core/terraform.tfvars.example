region           = "eu-frankfurt-1"
tenancy_ocid     = "ocid1.tenancy.oc1..REDACTED"
compartment_ocid = "ocid1.compartment-or-tenancy.oc1..REDACTED"
user_ocid        = "ocid1.user.oc1..REDACTED"
fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
private_key_path = "~/.config/oci/oci_private_key.pem"

ssh_public_key_path = "~/.ssh/id_ed25519.pub"
wireguard_port      = 51820

# Current fallback.
create_amd     = true
active_backend = "amd"

# Normal operation has no public SSH ingress.
emergency_ssh_cidr = null

# Promotion is deliberate and uses the verified capacity output:
# active_backend   = "a1"
# a1_private_ip_id = "ocid1.privateip.oc1..."
