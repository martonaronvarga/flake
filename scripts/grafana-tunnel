#!/usr/bin/env bash
set -euo pipefail

local_host="${GRAFANA_LOCAL_HOST:-127.0.0.1}"
local_port="${GRAFANA_LOCAL_PORT:-3000}"
remote_host="${GRAFANA_REMOTE_HOST:-10.200.200.2}"
remote_port="${GRAFANA_REMOTE_PORT:-3000}"
ssh_target="${GRAFANA_SSH_TARGET:-dusk}"

if command -v ss >/dev/null 2>&1; then
  if ss -ltn "sport = :${local_port}" | grep -q LISTEN; then
    echo "local port ${local_port} is already in use" >&2
    echo "try: GRAFANA_LOCAL_PORT=3001 $0" >&2
    exit 1
  fi
fi

echo "Grafana tunnel:"
echo "  http://${local_host}:${local_port}"
echo
echo "Press Ctrl-C to close the tunnel."

exec ssh \
  -N \
  -L "${local_host}:${local_port}:${remote_host}:${remote_port}" \
  "${ssh_target}"
