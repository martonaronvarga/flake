  mkKitty = p: ''
    background ${p.base00}
    foreground ${p.base05}
    cursor ${p.base05}
    selection_background ${p.base02}
    selection_foreground ${p.base05}
    url_color ${p.base0D}

    color0 ${p.base00}
    color1 ${p.base08}
    color2 ${p.base0B}
    color3 ${p.base0A}
    color4 ${p.base0D}
    color5 ${p.base0E}
    color6 ${p.base0C}
    color7 ${p.base05}
    color8 ${p.base03}
    color9 ${p.base08}
    color10 ${p.base0B}
    color11 ${p.base0A}
    color12 ${p.base0D}
    color13 ${p.base0E}
    color14 ${p.base0C}
    color15 ${p.base07}

    active_tab_foreground ${p.base00}
    active_tab_background ${p.base05}
    inactive_tab_foreground ${p.base04}
    inactive_tab_background ${p.base01}
    tab_bar_background ${p.base00}
  '';

  mkYaziFlavor = p: ''
    [manager]
    cwd = { fg = "${p.base0A}", bold = true }
    hovered = { fg = "${p.base00}", bg = "${p.base05}", bold = true }
    preview_hovered = { fg = "${p.base00}", bg = "${p.base0A}", bold = true }
    find_keyword = { fg = "${p.base0B}", bold = true, italic = true, underline = true }
    find_position = { fg = "${p.base0B}", bg = "reset", bold = true, italic = true }
    marker_copied = { fg = "${p.base0B}", bg = "${p.base0B}" }
    marker_cut = { fg = "${p.base08}", bg = "${p.base08}" }
    marker_marked = { fg = "${p.base0A}", bg = "${p.base0A}" }
    marker_selected = { fg = "${p.base0D}", bg = "${p.base0D}" }
    tab_active = { fg = "${p.base00}", bg = "${p.base05}", bold = true }
    tab_inactive = { fg = "${p.base04}", bg = "${p.base01}" }
    tab_width = 1
    count_copied = { fg = "${p.base00}", bg = "${p.base0B}" }
    count_cut = { fg = "${p.base00}", bg = "${p.base08}" }
    count_selected = { fg = "${p.base00}", bg = "${p.base0D}" }
    border_symbol = "│"
    border_style = { fg = "${p.base03}" }

    [mode]
    normal_main = { fg = "${p.base00}", bg = "${p.base05}", bold = true }
    normal_alt = { fg = "${p.base05}", bg = "${p.base01}" }
    select_main = { fg = "${p.base00}", bg = "${p.base0D}", bold = true }
    select_alt = { fg = "${p.base0D}", bg = "${p.base01}" }
    unset_main = { fg = "${p.base00}", bg = "${p.base0A}", bold = true }
    unset_alt = { fg = "${p.base0A}", bg = "${p.base01}" }

    [status]
    separator_open = ""
    separator_close = ""
    progress_label = { fg = "${p.base00}", bold = true }
    progress_normal = { fg = "${p.base0D}", bg = "${p.base02}" }
    progress_error = { fg = "${p.base08}", bg = "${p.base02}" }
    perm_sep = { fg = "${p.base04}", bold = true }
    perm_type = { fg = "${p.base08}" }
    perm_read = { fg = "${p.base05}", bold = true }
    perm_write = { fg = "${p.base0A}", bold = true }
    perm_exec = { fg = "${p.base0B}", bold = true }

    [pick]
    border = { fg = "${p.base0A}" }
    active = { fg = "${p.base0B}", bold = true }
    inactive = {}

    [input]
    border = { fg = "${p.base0A}" }
    title = {}
    value = {}
    selected = { reversed = true }

    [completion]
    border = { fg = "${p.base0A}" }

    [tasks]
    border = { fg = "${p.base0A}" }
    title = {}
    hovered = { fg = "${p.base05}", underline = true }

    [which]
    mask = { bg = "${p.base01}" }
    cand = { fg = "${p.base0A}" }
    rest = { fg = "${p.base05}" }
    desc = { fg = "${p.base0B}" }
    separator = "  "
    separator_style = { fg = "${p.base03}" }

    [help]
    on = { fg = "${p.base0A}" }
    run = { fg = "${p.base0B}" }
    desc = { fg = "${p.base05}" }
    hovered = { reversed = true, bold = true }
    footer = { fg = "${p.base07}", bg = "${p.base01}" }

    [notify]
    title_info = { fg = "${p.base05}" }
    title_warn = { fg = "${p.base0A}" }
    title_error = { fg = "${p.base08}" }

    [filetype]
    rules = [
      { mime = "image/*", fg = "${p.base0A}" },
      { mime = "{audio,video}/*", fg = "${p.base0D}" },
      { mime = "application/{zip,rar,7z*,tar,gzip,xz,zstd,bzip*,lzma,compress,archive,cpio,arj,xar,ms-cab*}", fg = "${p.base08}" },
      { mime = "application/{pdf,doc,rtf}", fg = "${p.base0A}" },
      { name = "*", fg = "${p.base05}" },
      { name = "*/", fg = "${p.base0B}" },
    ]
  '';

  mkHelixTheme = p: {
    inherits = "base16_default_dark";
    palette = {
      inherit
        (p)
        base00
        base01
        base02
        base03
        base04
        base05
        base06
        base07
        base08
        base09
        base0A
        base0B
        base0C
        base0D
        base0E
        base0F
        ;
    };
    "ui.background" = {bg = "base00";};
    "ui.text" = "base05";
    "ui.text.focus" = "base07";
    "ui.cursor" = {
      fg = "base00";
      bg = "base05";
    };
    "ui.cursorline.primary" = {bg = "base01";};
    "ui.selection" = {bg = "base02";};
    "ui.statusline" = {
      fg = "base05";
      bg = "base01";
    };
    "ui.statusline.inactive" = {
      fg = "base04";
      bg = "base00";
    };
    "ui.statusline.normal" = {
      fg = "base00";
      bg = "base05";
      modifiers = ["bold"];
    };
    "ui.statusline.insert" = {
      fg = "base00";
      bg = "base0B";
      modifiers = ["bold"];
    };
    "ui.statusline.select" = {
      fg = "base00";
      bg = "base0D";
      modifiers = ["bold"];
    };
    "ui.virtual.whitespace" = "base03";
    "ui.virtual.indent-guide" = "base02";
    "ui.linenr" = "base03";
    "ui.linenr.selected" = "base05";
    "ui.popup" = {bg = "base01";};
    "ui.window" = "base03";
    "ui.help" = {
      fg = "base05";
      bg = "base01";
    };
    keyword = "base0E";
    operator = "base05";
    function = "base0D";
    type = "base0A";
    string = "base0B";
    constant = "base09";
    variable = "base05";
    comment = {
      fg = "base03";
      modifiers = ["italic"];
    };
    attribute = "base0A";
    namespace = "base0D";
    tag = "base08";
    label = "base0A";
    error = "base08";
    warning = "base0A";
    info = "base0D";
    hint = "base0C";
    diagnostic = {underline = {style = "curl";};};
    "diagnostic.error" = {underline = {color = "base08";};};
    "diagnostic.warning" = {underline = {color = "base0A";};};
    "diagnostic.info" = {underline = {color = "base0D";};};
    "diagnostic.hint" = {underline = {color = "base0C";};};
  };
in {
  names = builtins.attrNames palettes;
  themes =
    builtins.mapAttrs (slug: palette: {
      inherit slug palette;
      inherit (palette) name;
      kitty = mkKitty palette;
      yaziFlavor = mkYaziFlavor palette;
      helix = mkHelixTheme palette;
    })
    palettes;
}
