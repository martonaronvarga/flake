+def get_access_token_from_refresh(refresh_token, client_id, client_secret, debug):
+    """
+    Exchange a Google OAuth2 refresh token for an access token.
+    Returns the access token as a string.
+    """
+    data = parse.urlencode(
+        {
+            "grant_type": "refresh_token",
+            "refresh_token": refresh_token,
+            "client_id": client_id,
+            "client_secret": client_secret,
+        }
+    ).encode("utf-8")
+    req = request.Request(
+        "https://oauth2.googleapis.com/token",
+        data=data,
+        headers={"Content-Type": "application/x-www-form-urlencoded"},
+        method="POST",
+    )
+
+    try:
+        with request.urlopen(req) as resp:
+            if debug:
+                debug_response(resp)
+            resp_data = resp.read().decode("utf-8")
+            token_json = json.loads(resp_data)
+            if "access_token" not in token_json:
+                raise ValueError(f"Failed to obtain access token: {resp_data}")
+            return token_json["access_token"]
+    except error.HTTPError as e:
+        body = e.read().decode("utf-8")
+        raise ValueError(f"HTTP error while obtaining access token: {e.code} {body}")
+
+
