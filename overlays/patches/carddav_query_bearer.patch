From f63de4d07df1f7c5d6bbedd299297e597b8556b1 Mon Sep 17 00:00:00 2001
From: "Marton A. Varga" <martonaronvarga@gmail.com>
Date: Sat, 7 Feb 2026 20:13:03 +0100
Subject: [PATCH aerc] contrib: add OAuth2 bearer auth support to carddav-query

Extend carddav-query to support OAuth2 bearer authentication
in addition to Basic Auth.

---
Changes in v2:
- Use https+oauthbearer:// URL scheme instead of a separate auth-mode option.
- Remove Google-specific OAuth2 token exchange.
- Expect carddav-source-cred-cmd (e.g. oama) to provide the bearer token.
- Format with ruff.
- Wrap help text.

Signed-off-by: Marton A. Varga <martonaronvarga@gmail.com>
---
 contrib/carddav-query   | 36 ++++++++++++++++++++++++++++--------
 doc/carddav-query.1.scd | 19 ++++++++++++++-----
 2 files changed, 42 insertions(+), 13 deletions(-)

diff --git a/contrib/carddav-query b/contrib/carddav-query
index 8e4f59c9..5ed9a49f 100755
--- a/contrib/carddav-query
+++ b/contrib/carddav-query
@@ -74,6 +74,14 @@ def http_request_xml(
     debug: bool = False,
     **headers,
 ) -> xml.Element:
+    uri = parse.urlparse(url)
+    oauthbearer = uri.scheme.endswith("+oauthbearer")
+    if oauthbearer:
+        scheme = uri.scheme[: -len("+oauthbearer")]
+        if scheme not in ("http", "https"):
+            raise ValueError(f"unsupported OAuthBearer URL scheme: {uri.scheme}")
+        url = uri._replace(scheme=scheme).geturl()
+
     req = request.Request(
         url=url,
         method=method,
@@ -83,7 +91,14 @@ def http_request_xml(
         },
         data=xml.tostring(data, encoding="utf-8", xml_declaration=True),
     )
-    if username is not None and password is not None:
+    if oauthbearer:
+        if not password:
+            raise ValueError(
+                "+oauthbearer requires a token via --password, "
+                "carddav-source, or carddav-source-cred-cmd"
+            )
+        req.add_header("Authorization", f"Bearer {password}")
+    elif username is not None and password is not None:
         auth = f"{username}:{password}"
         auth = base64.standard_b64encode(auth.encode("utf-8")).decode("ascii")
         req.add_header("Authorization", f"Basic {auth}")
@@ -121,7 +136,9 @@ def parse_vcard(txt):
         if line.startswith("FN:"):
             name = line[len("FN:") :].replace("\\,", ",")
             continue
-        match = re.match(r"^(?:\w+\.)?EMAIL(?:;[\w-]+=[^;:]+)*:(.+@.+)$", line, flags=re.I)
+        match = re.match(
+            r"^(?:\w+\.)?EMAIL(?:;[\w-]+=[^;:]+)*:(.+@.+)$", line, flags=re.I
+        )
         if match:
             email = match.group(1).lower().replace("\\,", ",")
             if email not in emails:
@@ -181,7 +198,7 @@ def parse_args():
         help="""
         INI configuration key to lookup in CONFIG_SECTION from CONFIG_FILE.
         The value must respect the following format:
-        https?://USERNAME[:PASSWORD]@HOSTNAME/PATH/TO/ADDRESSBOOK.
+        https?[+oauthbearer]://USERNAME[:PASSWORD]@HOSTNAME/PATH/TO/ADDRESSBOOK.
         Both USERNAME and PASSWORD must be percent encoded.
         """,
     )
@@ -214,7 +231,8 @@ def parse_args():
         "-p",
         "--password",
         help="""
-        Password for the specified user. Overrides configuration file.
+        Password or access token (if +oauthbearer) for the specified user.
+        Overrides configuration file.
         """,
     )
     parser.add_argument(
@@ -243,6 +261,7 @@ def parse_args():
     if source is not None:
         try:
             u = parse.urlparse(source)
+
             if args.username is None and u.username is not None:
                 args.username = parse.unquote(u.username)
             if args.password is None and u.password is not None:
@@ -252,10 +271,11 @@ def parse_args():
                     cred_cmd, shell=True, text=True, encoding="utf-8"
                 ).strip()
             if args.server_url is None:
-                args.server_url = f"{u.scheme}://{u.hostname}"
-                if u.port is not None:
-                    args.server_url += f":{u.port}"
-                args.server_url += u.path
+                args.server_url = u._replace(
+                    netloc=u.netloc.rsplit("@", maxsplit=1)[-1],
+                    params="",
+                    fragment="",
+                ).geturl()
         except ValueError as e:
             parser.error(f"{args.config_file}: {e}")
     if args.server_url is None:
diff --git a/doc/carddav-query.1.scd b/doc/carddav-query.1.scd
index e12c680b..f745d5df 100644
--- a/doc/carddav-query.1.scd
+++ b/doc/carddav-query.1.scd
@@ -40,11 +40,15 @@ This tool has been tailored for use as *address-book-cmd* in *aerc-config*(5).
 	INI configuration key to lookup in _<section>_ from _<file>_. The value
 	must respect the following format:
 
-		https?://_<username>_[:_<password>_]@_<hostname>_/_<path/to/addressbook>_
+		_<scheme>_://_<username>_[:_<password>_]@_<hostname>_/_<path/to/addressbook>_
+
+	Valid schemes are *http*, *https*, *http+oauthbearer* and
+	*https+oauthbearer*.
 
 	Both _<username>_ and _<password>_ must be percent encoded. If
 	_<password>_ is omitted, it can be provided via *--config-key-cred-cmd*
-	or *--password*.
+	or *--password*. With *+oauthbearer*, _<password>_ must be an OAuth
+	bearer access token.
 
 	Default: _carddav-source_
 
@@ -62,7 +66,8 @@ This tool has been tailored for use as *address-book-cmd* in *aerc-config*(5).
 	Username to authenticate on the server. Overrides configuration file.
 
 *-p* _<password>_, *--password* _<password>_
-	Password for the specified user. Overrides configuration file.
+	Password, or access token if *+oauthbearer* is used, for the specified
+	user. Overrides configuration file.
 
 # POSITIONAL ARGUMENTS
 
@@ -87,11 +92,15 @@ address-book-cmd = carddav-query -S fastmail %s
 
 ```
 [gmail]
-carddav-source = https://johndoe%40gmail.com@www.googleapis.com/carddav/v1/principals/johndoe@gmail.com/lists/default
-carddav-source-cred-cmd = pass gmail.com/johndoe
+carddav-source = https+oauthbearer://johndoe%40gmail.com@www.googleapis.com/carddav/v1/principals/johndoe@gmail.com/lists/default
+carddav-source-cred-cmd = oama access johndoe@gmail.com
 address-book-cmd = carddav-query -S gmail %s
 ```
 
+The *+oauthbearer* scheme sends the password or *carddav-source-cred-cmd*
+output as a bearer access token. A helper such as *oama* can be used to refresh
+OAuth tokens outside of *carddav-query*.
+
 # SEE ALSO
 
 *aerc-config*(5)
